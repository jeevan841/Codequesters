# =============================================================================
# .env.example — Codequesters Voice CRM
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to git (it is already in .gitignore).
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Full DSN used by app.py (required — no default)
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/voice_ai

# Individual fields used by create_db.py bootstrap script
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=voice_ai

# ─── Security ─────────────────────────────────────────────────────────────────
# 32-byte random hex string — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=CHANGE_ME_generate_a_real_secret

# Comma-separated list of origins allowed to make cross-origin requests.
# Include your local dev URL and any production domain.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Set to "true" in production (requires HTTPS).  Leave "false" for local dev.
SECURE_COOKIES=false

# ─── OAuth — Google ───────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth — GitHub ───────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key

# Set to "true" to use a local Ollama model instead of Groq
USE_LOCAL_LLM=false

# Name of the Ollama model to use when USE_LOCAL_LLM=true
LOCAL_MODEL_NAME=llama3

# ─── Exotel Telephony ─────────────────────────────────────────────────────────
# Find these in your Exotel dashboard: https://my.exotel.com
EXOTEL_SID=your-exotel-sid
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-api-token
EXOTEL_VIRTUAL_NUMBER=your-exotel-virtual-number

# Your real phone number for the /voice endpoint (must include country code)
MY_PHONE=+91XXXXXXXXXX
